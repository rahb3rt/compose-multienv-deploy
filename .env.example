# ══════════════════════════════════════════════════════════════════════════════
# Multi-Environment Compose Platform — Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
# Copy to .env and fill in your values:  cp .env.example .env

# ─── Environment ──────────────────────────────────────────────────────────
# Set these to match your domain/deployment
APP_ORIGIN=https://app.example.com
API_ORIGIN=https://api.example.com
EMAIL_ORIGIN=https://email.example.com

# Path to service repos (relative to this file, or absolute)
REPOS_DIR=..

# Path to nginx config/certs directory
NGINX_DIR=../nginx

# ─── Database ─────────────────────────────────────────────────────────────
DB_USER=admin
DB_PASSWORD=
MYSQL_DATABASE=platform
MYSQL_PORT=6603
MYSQL_HEALTH_USER=health
MYSQL_HEALTH_PASSWORD=

# ─── MinIO / S3 ──────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=
MINIO_API_PORT=5003
MINIO_CONSOLE_PORT=5004
MINIO_PUBLIC_ENDPOINT=https://s3.example.com

# ─── OpenAI ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── App / Auth ───────────────────────────────────────────────────────────
API_KEY=
SESSION_SECRET=
JWT_SECRET=platform

# ─── Google OAuth ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PROJECT_ID=
GOOGLE_REDIRECT_URI=https://email.example.com/oauth2callback

# ─── Meta / Instagram ────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_CONFIG_ID=

# ─── Stripe ───────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ─── Seam (Smart Locks) ──────────────────────────────────────────────────
SEAM_API_KEY=
SEAM_WEBHOOK_SECRET=

# ─── iMessage / SMS Bridge ───────────────────────────────────────────────
IMESSAGE_BRIDGE_API_KEY=platform
BLUEBUBBLES_BASE_URL=
BLUEBUBBLES_PASSWORD=
CRM_INGEST_API_KEY=

# ─── Email / Gmail ────────────────────────────────────────────────────────
GMAIL_USER=
GMAIL_PASS=
LOB_API_KEY=

# ─── Monitoring ───────────────────────────────────────────────────────────
MONITORING_USER=admin
MONITORING_PASS=
RUM_INGEST_KEY=platform
MONITORING_INTERNAL_KEY=platform

# ─── Public Website ──────────────────────────────────────────────────────
WEB_ADMIN_USERNAME=admin
WEB_ADMIN_PASSWORD=changeme
WEB_SESSION_SECRET=

# ─── Telemetry Device ────────────────────────────────────────────────────
TELEMETRY_DEVICE_TOKEN=platform

# ─── Container Runtime ───────────────────────────────────────────────────
# PODMAN_SOCK=/run/podman/podman.sock
